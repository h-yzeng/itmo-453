{
  "id": null,
  "uid": "availability",
  "title": "Availability",
  "tags": ["availability", "uptime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "About This Dashboard",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "This dashboard tracks whether each monitored target is reachable. The panels below read the Prometheus `up` metric, which is 1 when a scrape target responds and 0 when it does not. Uptime Kuma runs alongside this stack as an independent black box uptime checker and should be reviewed separately at its own dashboard for HTTP-level availability history."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Prometheus",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "up{job=\"prometheus\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 1 },
                "1": { "text": "UP", "color": "green", "index": 0 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Node Exporter",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "up{job=\"node\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 1 },
                "1": { "text": "UP", "color": "green", "index": 0 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "cAdvisor",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "up{job=\"cadvisor\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 1 },
                "1": { "text": "UP", "color": "green", "index": 0 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Grafana",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "up{job=\"grafana\"}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 1 },
                "1": { "text": "UP", "color": "green", "index": 0 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Target Availability Over Time",
      "description": "Shows each scrape target's up/down state over the selected window. A dip to 0 for a given target means it was unreachable and, if sustained past one minute, would trigger the corresponding downtime alert.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "stacking": { "mode": "none" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Average Uptime (Selected Window)",
      "description": "Percentage of scrapes in the selected time range where every target responded successfully",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus_ds" },
          "expr": "avg(avg_over_time(up[6h])) * 100",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      }
    }
  ]
}
