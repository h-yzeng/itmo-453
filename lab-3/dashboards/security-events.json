{
  "id": null,
  "uid": "security-events",
  "title": "Security Events",
  "tags": [
    "security",
    "logs"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Failed Logins (Last 5 Minutes)",
      "description": "Count of failed Grafana authentication attempts in the trailing 5 minute window. This is the same value the Failed Login Attempts alert evaluates.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki_ds"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki_ds"
          },
          "queryType": "instant",
          "expr": "sum(count_over_time({container=\"grafana\"} |= \"failed to authenticate identity\" != \"lokiPath=\" [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 3
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed Login Alert Threshold",
      "description": "Static reference showing the count that triggers the Failed Login Attempts alert",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki_ds"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki_ds"
          },
          "queryType": "instant",
          "expr": "vector(5)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Failed Login Attempts Over Time",
      "description": "Failed Grafana login attempts per minute. Sustained spikes above the alert threshold line indicate a possible brute force attempt against the admin account.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki_ds"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki_ds"
          },
          "expr": "sum(count_over_time({container=\"grafana\"} |= \"failed to authenticate identity\" != \"lokiPath=\" [1m]))",
          "legendFormat": "Failed logins/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 30,
            "lineWidth": 1
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "SSH Connection Activity",
      "description": "Volume of log lines produced by the SSH target container, included as a secondary indicator of external connection attempts against the exposed SSH service.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki_ds"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki_ds"
          },
          "expr": "sum(count_over_time({container=\"ssh-target\"} [1m]))",
          "legendFormat": "ssh-target log lines/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 30,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Live Failed Login Log",
      "description": "Raw log lines for rejected Grafana login requests, showing the source IP, path, and unauthorized status for each attempt.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "loki",
        "uid": "loki_ds"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki_ds"
          },
          "expr": "{container=\"grafana\"} |= \"failed to authenticate identity\" != \"lokiPath=\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}