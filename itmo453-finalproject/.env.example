DOMAIN=yourname.duckdns.org
STATUS_DOMAIN=yourname-status.duckdns.org
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-before-deploying
TZ=America/Chicago

# SMTP settings so Grafana can send alert emails.
# Using Gmail requires an App Password, not your regular account password,
# since Gmail blocks plain password SMTP logins.
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your16charapppassword
SMTP_FROM=you@gmail.com
